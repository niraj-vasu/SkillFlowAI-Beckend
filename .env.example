# Database (local SQLite file; created automatically)
DATABASE_URL=sqlite:///./skillflow.db

# CORS: comma-separated origins, or * for any (local demo default).
# With *, credentials are disabled — auth uses the Authorization bearer header.
CORS_ORIGINS=*

# Auth (local demo defaults — change JWT_SECRET for anything real)
JWT_SECRET=dev-insecure-secret-change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=720

# Max serialized size (chars) of a stored report payload
MAX_REPORT_PAYLOAD_CHARS=200000
