              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Returns a JWT and the user object. Test script stores the token in {{fresher_token}}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fresher@skillflow.local\",\n  \"password\": \"Demo@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "pm.collectionVariables.set('fresher_token', res.access_token);",
                  "pm.collectionVariables.set('fresher_id', res.user.id);",
                  "pm.test('logged in as fresher', function () { pm.expect(res.user.role).to.eql('FRESHER'); });"
