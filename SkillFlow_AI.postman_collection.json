          "item": [
            {
              "name": "Create Roadmap",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{fresher_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/freshers/me/roadmaps",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "freshers",
                    "me",
                    "roadmaps"
                  ]
                },
                "description": "Creates the next roadmap version and sets it current. IDEMPOTENT (change #7): re-POSTing the same client_roadmap_id returns the existing roadmap (200) instead of a new version \u2014 a new version needs a new client_roadmap_id. roadmap_payload.current_task holds the backend-owned task the daily report is graded against. Required: client_roadmap_id, title, target_role, roadmap_payload (non-empty). Stores {{roadmap_id}}.",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"client_roadmap_id\": \"WEB-RM-001\",\n  \"title\": \"Fresher Onboarding Roadmap\",\n  \"target_role\": \"<the fresher's target role / department>\",\n  \"start_date\": \"2026-07-20\",\n  \"target_completion_date\": \"2026-10-20\",\n  \"roadmap_payload\": {\n    \"schema_version\": \"1.0\",\n    \"generation_mode\": \"diagnostic\",\n    \"pace_status\": \"no_evidence\",\n    \"weeks\": [],\n    \"competencies\": [\n      \"<competency_key>\",\n      \"<competency_key>\"\n    ],\n    \"milestones\": [],\n    \"completion_criteria\": \"All weeks completed with passing evaluations\",\n    \"current_task\": {\n      \"task_id\": \"TASK-001\",\n      \"task_title\": \"Week 1 diagnostic task\",\n      \"employee_facing_instruction\": \"Complete the task your roadmap describes and submit your work.\",\n      \"sample_input\": {},\n      \"required_resources\": [],\n      \"acceptance_criteria\": [\n        \"Meets the stated objective\",\n        \"Work is documented\"\n      ],\n      \"evaluation_criteria\": [\n        \"Correctness\",\n        \"Clarity\",\n        \"Ownership\"\n      ]\n    }\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var res = pm.response.json();",
                      "pm.collectionVariables.set('roadmap_id', res.id);",
                      "pm.test('roadmap created', function () { pm.expect(res.status).to.eql('ACTIVE'); });"
                    ]
                  }
                }
              ]
            },
