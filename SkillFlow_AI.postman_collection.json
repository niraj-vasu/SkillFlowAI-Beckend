        {
          "name": "Reports",
          "description": "",
          "item": [
            {
              "name": "Create Daily Report",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{fresher_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/freshers/me/reports/daily",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "freshers",
                    "me",
                    "reports",
                    "daily"
                  ]
                },
                "description": "Submit the daily evaluation. Required top-level: client_report_id, roadmap_id, report_date, overall_score (0-100), report_payload. Required in report_payload: task_id, submission, evaluation. SOURCE OF TRUTH (change #4): the backend looks up current_task by task_id and OVERWRITES report_payload.evaluation.acceptance_criteria / .evaluation_criteria with the saved roadmap values (adding criteria_source: 'backend_roadmap' and a current_task_snapshot) \u2014 any criteria you send are ignored. Idempotent on client_report_id. Stores {{report_id}}.",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"client_report_id\": \"WEB-DAILY-2026-07-18-USR-F001\",\n  \"roadmap_id\": \"{{roadmap_id}}\",\n  \"report_date\": \"2026-07-18\",\n  \"overall_score\": 76,\n  \"needs_human_interaction\": true,\n  \"report_payload\": {\n    \"schema_version\": \"1.0\",\n    \"task_id\": \"TASK-001\",\n    \"submission\": {\n      \"summary\": \"<what the employee submitted>\",\n      \"reference\": \"<link or id>\"\n    },\n    \"ai_usage_disclosure\": {\n      \"used_ai\": true,\n      \"tools\": [\n        \"<tool>\"\n      ],\n      \"what_ai_generated\": \"<...>\",\n      \"what_employee_corrected\": \"<...>\"\n    },\n    \"evaluation\": {\n      \"verified_skills\": [\n        \"<skill name>\",\n        \"<skill name>\"\n      ],\n      \"weak_areas\": [\n        \"<gap>\"\n      ],\n      \"evidence\": [\n        \"<evidence item>\"\n      ],\n      \"dashboard_update\": {\n        \"next_focus\": \"<next focus>\",\n        \"improvement_pct\": 12.5\n      },\n      \"kpis\": [\n        {\n          \"key\": \"<kpi_key>\",\n          \"name\": \"<KPI Name>\",\n          \"score\": 78,\n          \"confidence\": 0.88\n        }\n      ]\n    },\n    \"qna\": {\n      \"questions\": [\n        {\n          \"question\": \"<question the agent asked>\",\n          \"answer\": \"<employee answer>\",\n          \"score\": 82\n        }\n      ],\n      \"summary\": \"<short summary>\"\n    }\n  }\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var res = pm.response.json();",
                      "pm.collectionVariables.set('report_id', res.id);",
                      "pm.test('report stored', function () { pm.expect(res.id).to.be.a('string'); });",
                      "pm.test('criteria came from backend', function () {",
                      "  pm.expect(res.report_payload.evaluation.criteria_source).to.eql('backend_roadmap');",
                      "});"
                    ]
                  }
                }
              ]
            },
